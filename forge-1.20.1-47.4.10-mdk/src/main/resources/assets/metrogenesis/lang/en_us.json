  "gui.metrogenesis.catalog.desc.title": "Function",
  "gui.metrogenesis.catalog.desc.cat.residential": "Housing for citizens; provides the city's population capacity.",
  "gui.metrogenesis.catalog.desc.cat.public": "Public services: education, healthcare and civic administration.",
  "gui.metrogenesis.catalog.desc.cat.infrastructure": "Roads, walls and the skeleton that keeps a city running.",
  "gui.metrogenesis.catalog.desc.cat.production": "Turns resources into goods, driving city output.",
  "gui.metrogenesis.catalog.desc.cat.commercial": "Trade and circulation hubs that animate the economy.",
  "gui.metrogenesis.catalog.desc.cat.agriculture": "Farming, weaving, fishing and herding that feed the city.",
  "gui.metrogenesis.catalog.desc.cat.military": "Defensive and combat facilities that guard the city.",
  "gui.metrogenesis.catalog.desc.cat.seamless": "Tileable continuous structures used to seam landscapes.",
  "gui.metrogenesis.catalog.desc.cat.other": "Decoration and miscellaneous builds that enrich the cityscape.",
  "gui.metrogenesis.catalog.desc.farmer": "Grows and harvests crops to feed the city.",
  "gui.metrogenesis.catalog.desc.townhall": "City core: manages citizens, taxes and municipal affairs.",
  "gui.metrogenesis.catalog.desc.warehouse": "Stores supplies, the hub of the city's material flow.",
  "gui.metrogenesis.catalog.desc.builder": "Builder's base that turns blueprints into real structures.",
  "gui.metrogenesis.catalog.desc.miner": "Mines stone and ore, the source of build materials.",
  "gui.metrogenesis.catalog.desc.lumberjack": "Fells and replants trees, supplying timber.",
  "gui.metrogenesis.catalog.desc.cook": "Cooks ingredients into meals for citizens.",
  "gui.metrogenesis.catalog.desc.guard": "Patrols and guards the city's peace and defense.",
  "gui.metrogenesis.catalog.desc.archery": "Archer training camp that boosts military defense.",
  "gui.metrogenesis.catalog.desc.barracks": "Barracks that train and house combat units.",
  "gui.metrogenesis.catalog.desc.school": "Educates young citizens, raising population quality.",
  "gui.metrogenesis.catalog.desc.library": "Books and research that speed up science and culture.",
  "gui.metrogenesis.catalog.desc.hospital": "Treats the sick and wounded, keeping citizens healthy.",
  "gui.metrogenesis.catalog.desc.blacksmith": "Forges tools and gear for building and arms.",
  "gui.metrogenesis.catalog.desc.bakery": "Bakes bread and staples, steadying food supply.",
  "gui.metrogenesis.catalog.desc.sawmill": "Processes logs into planks for construction.",
  "gui.metrogenesis.catalog.desc.smelter": "Smelts metal ingots, precursor to manufacturing.",
  "gui.metrogenesis.catalog.desc.stonequarry": "Quarry that produces stone at scale.",
  "gui.metrogenesis.catalog.desc.fisherman": "Catches aquatic food, diversifying the diet.",
  "gui.metrogenesis.catalog.desc.cowboy": "Herds cattle, supplying meat and leather.",
  "gui.metrogenesis.catalog.desc.shepherd": "Keeps sheep, yielding wool and meat.",
  "gui.metrogenesis.catalog.desc.fletcher": "Crafts bows and arrows, ranged weapon parts.",
  "gui.metrogenesis.catalog.desc.composter": "Composts waste into agricultural nutrients.",
  "gui.metrogenesis.catalog.desc.chickenherder": "Raises poultry for eggs and meat.",
  "gui.metrogenesis.catalog.desc.swineherd": "Raises hogs, supplying meat.",
  "gui.metrogenesis.catalog.desc.beekeeper": "Keeps bees, yielding honey and wax.",
  "gui.metrogenesis.catalog.desc.glassblower": "Blows glass for building materials and wares.",
  "gui.metrogenesis.catalog.desc.university": "Higher education and research, training specialists.",
  "gui.metrogenesis.catalog.desc.enchantment": "Enchanting workshop that empowers gear and tools.",
  "gui.metrogenesis.catalog.desc.tavern": "Tavern that lifts citizen happiness and social life.",
  "gui.metrogenesis.catalog.desc.market": "Market that promotes trade and circulation.",
